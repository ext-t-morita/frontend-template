{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "typeRoots": ["./apps/web/node_modules/@types"],
    "types": ["vitest/globals", "node"]
  },
  "include": ["tests", "vitest.config.ts"]
}
