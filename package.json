{
  "name": "@repo/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "storybook": "storybook dev -p 6006 -c .storybook",
    "build-storybook": "storybook build -c .storybook",
    "storybook:a11y": "storybook dev -p 6006 -c .storybook --docs",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:list": "playwright test -c playwright.config.ts --list",
    "typecheck": "pnpm exec tsc -p packages/design-tokens/tsconfig.json && pnpm exec tsc -p packages/ui/tsconfig.json && pnpm exec tsc -p tsconfig.json",
    "tokens:build": "node --experimental-strip-types packages/design-tokens/scripts/generate-css.ts",
    "check": "pnpm lint && pnpm format:check && pnpm test && pnpm typecheck && pnpm build",
    "lint:framework": "pnpm exec eslint --max-warnings 0 --config eslint.config.mjs app components features packages stories .storybook next.config.ts playwright.config.ts",
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && pnpm exec lefthook install || true",
    "hooks:install": "pnpm exec lefthook install",
    "lint": "pnpm exec biome lint . --no-errors-on-unmatched",
    "lint:fix": "pnpm exec biome lint . --write --no-errors-on-unmatched",
    "format": "pnpm run format:biome && pnpm run format:prettier",
    "format:check": "pnpm run format:check:biome && pnpm run format:check:prettier",
    "format:biome": "pnpm exec biome format . --write --no-errors-on-unmatched",
    "format:check:biome": "pnpm exec biome format . --no-errors-on-unmatched",
    "format:prettier": "pnpm exec prettier --write .",
    "format:check:prettier": "pnpm exec prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@repo/design-tokens": "workspace:*",
    "@repo/ui": "workspace:*",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@next/eslint-plugin-next": "16.2.1",
    "@playwright/test": "1.58.2",
    "@storybook/addon-a11y": "10.3.3",
    "@storybook/nextjs": "10.3.3",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "22.19.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-storybook": "10.3.3",
    "lefthook": "2.1.4",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "storybook": "10.3.3",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
