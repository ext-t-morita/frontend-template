{
  "name": "user-provisioning",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=10.24.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:webpack": "NEXT_BUILDER=webpack next build",
    "start": "next start",
    "lint": "pnpm lint:biome && pnpm lint:eslint",
    "lint:biome": "biome check .",
    "lint:eslint": "eslint .",
    "format": "pnpm format:prettier && pnpm format:biome",
    "format:prettier": "prettier --write \"**/*.{md,mdx,json,yml,yaml,css,scss,html}\"",
    "format:biome": "biome format --write src .storybook tailwind.config.ts vitest.config.ts eslint.config.mjs",
    "format:unsafe": "biome check --write --unsafe .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:storybook": "test-storybook --ci",
    "prepare": "lefthook install",
    "chromatic": "npx chromatic --project-token=chpt_3f4ca0f5388a4ee",
    "tokens:build": "node --experimental-strip-types scripts/tokens/generate-css.ts && pnpm exec biome format --write src/ui/tokens/variables.css"
  },
  "imports": {
    "#.storybook/*": "./.storybook/*"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-a11y": "^10.1.2",
    "@storybook/addon-docs": "^10.1.2",
    "@storybook/addon-onboarding": "^10.1.2",
    "@storybook/addon-vitest": "^10.1.2",
    "@storybook/test-runner": "^0.24.2",
    "@playwright/test": "^1.57.0",
    "@storybook/nextjs-vite": "^10.1.2",
    "@tailwindcss/postcss": "^4.1.17",
    "tailwindcss": "^4.1.17",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.0.14",
    "@vitest/coverage-v8": "^4.0.14",
    "eslint": "^9",
    "eslint-config-next": "16.0.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.1.2",
    "lefthook": "2.0.4",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.3",
    "storybook": "^10.1.2",
    "typescript": "^5",
    "vite": "^7.2.4",
    "vitest": "^4.0.14",
    "tsx": "^4.16.1"
  },
  "packageManager": "pnpm@10.24.0"
}
